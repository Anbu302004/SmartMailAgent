# Server
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=smartmail_agent

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Email Agent
AGENT_CRON_SCHEDULE=*/5 * * * *

# Cleanup Agent (default: 2:00 AM on the 1st of every month)
CLEANUP_CRON_SCHEDULE=0 2 1 * *

# IMAP (per-user storage coming soon — use these as defaults for now)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_app_password
